{
  "name": "discord-bot",
  "private": true,
  "type": "module",
  "scripts": {
    "start": "bun run src/Index.ts",
    "typecheck": "tsc --noEmit",
    "build": "bun run typecheck && bun build ./src/Index.ts --target=bun > /dev/null"
  },
  "engines": {
    "bun": ">=1.3"
  },
  "dependencies": {
    "discord.js": "^14.26.4",
    "jimp": "^1.6.1"
  },
  "devDependencies": {
    "@types/bun": "^1.3.14",
    "typescript": "^6.0.3"
  }
}
