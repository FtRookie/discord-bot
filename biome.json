{
	"$schema": "https://biomejs.dev/schemas/2.5.4/schema.json",
	"files": { "includes": ["src/**/*.ts"] },
	"formatter": {
		"enabled": true,
		"indentStyle": "tab",
		"indentWidth": 4,
		"lineWidth": 120,
		"lineEnding": "lf"
	},
	"assist": {
		"enabled": true,
		"actions": {
			"source": { "organizeImports": "on" }
		}
	},
	"javascript": {
		"formatter": {
			"quoteStyle": "double",
			"semicolons": "always",
			"trailingCommas": "all"
		}
	},
	"linter": {
		"enabled": true,
		"rules": {
			"preset": "recommended",
			"suspicious": { "noExplicitAny": "error" },
			"style": {
				"useConsistentMemberAccessibility": {
					"level": "warn",
					"options": { "accessibility": "noPublic" }
				}
			}
		}
	}
}
